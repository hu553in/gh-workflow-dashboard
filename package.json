{
  "name": "gh-workflow-dashboard",
  "description": "Client-side dashboard for monitoring GitHub Actions workflows across repositories.",
  "author": "hu553in",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.5.0",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3",
    "stylelint": "^17.9.1",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^8.0.10"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "check": "lefthook run check --all-files --force",
    "check:fix": "lefthook run check-fix --all-files --force",
    "prepare": "command -v lefthook && lefthook install || true"
  },
  "browserslist": [
    "defaults",
    "fully supports es6-module"
  ]
}
