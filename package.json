{
  "name": "gh-workflow-dashboard",
  "description": "A client-side dashboard for monitoring GitHub Actions workflows across repositories. It runs entirely in the browser.",
  "author": "hu553in",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.7.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.9.4",
    "stylelint": "^17.14.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "test": "vitest run --passWithNoTests",
    "check": "lefthook run check --all-files --force",
    "check:fix": "lefthook run check-fix --all-files --force",
    "prepare": "command -v lefthook && lefthook install || true"
  },
  "browserslist": [
    "defaults",
    "fully supports es6-module"
  ],
  "dependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0"
  }
}
