{
  "name": "gh-workflow-dashboard",
  "version": "0.1.0",
  "description": "A client-side dashboard for monitoring GitHub Actions workflows across repositories.",
  "author": "Ruslan Khasanshin",
  "repository": "https://github.com/hu553in/gh-workflow-dashboard",
  "homepage": "https://gh-workflow-dashboard.vercel.app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "prettier -u -c . && eslint --max-warnings 0 . && stylelint --max-warnings 0 --ignore-path .gitignore '**/*.css'",
    "lint:fix": "prettier -u -w . && eslint --max-warnings 0 --fix . && stylelint --max-warnings 0 --fix --ignore-path .gitignore '**/*.css'",
    "check:workflows": "bunx github-actionlint",
    "check:unused": "knip",
    "check:vulns": "bun audit --prod --audit-level=high",
    "check": "bun lint && bun check:workflows && bun run build && bun check:unused && bun check:vulns && bun test:coverage",
    "check:fix": "bun lint:fix && bun check",
    "test": "vitest run",
    "test:coverage": "bun run test --coverage",
    "prepare": "if [ -n \"${CI:-}\" ] || [ \"${LEFTHOOK:-}\" = \"0\" ]; then exit 0; fi; lefthook install"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.18",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "globals": "^17.7.0",
    "knip": "^6.27.0",
    "lefthook": "^2.1.10",
    "prettier": "^3.9.6",
    "stylelint": "^17.14.1",
    "stylelint-config-standard": "^40.0.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "packageManager": "bun@1.3.14"
}
